{
  "manifest_version": 1,
  "type": "device",
  "name": "Tuya",
  "description": {
    "en": "Tuya / Smart Life smart sockets and energy meters over the cloud, with optional local control.",
    "fr": "Prises et compteurs d'énergie Tuya / Smart Life via le cloud, avec contrôle local optionnel."
  },
  "version": "1.2.0",
  "docker_image": "ghcr.io/terdious/gladys-tuya:1.2.0",
  "gladys_version": ">=4.62.0",
  "cover_image": "https://raw.githubusercontent.com/Terdious/gladys-tuya/master/cover.png",
  "network_discovery": [
    {
      "type": "udp-broadcast",
      "ports": [6666, 6667, 7000]
    }
  ],
  "transports": ["local", "cloud"],
  "actions": [
    {
      "key": "detect_protocol",
      "label": {
        "en": "Detect local protocol (manual IP)",
        "fr": "Détecter le protocole local (IP manuelle)"
      },
      "description": {
        "en": "For a device the LAN scan did not find: enter its IP to detect the local protocol version and enable local mode.",
        "fr": "Pour un appareil non trouvé par le scan LAN : saisissez son IP pour détecter la version de protocole locale et activer le mode local."
      },
      "timeout_seconds": 60,
      "fields": [
        {
          "key": "device",
          "type": "string",
          "label": {
            "en": "Device (name or Tuya ID)",
            "fr": "Appareil (nom ou identifiant Tuya)"
          },
          "description": {
            "en": "The device name as shown in Gladys, or its Tuya ID.",
            "fr": "Le nom de l'appareil tel qu'affiché dans Gladys, ou son identifiant Tuya."
          },
          "required": true
        },
        {
          "key": "ip",
          "type": "string",
          "label": {
            "en": "Device IP address",
            "fr": "Adresse IP de l'appareil"
          },
          "required": true
        }
      ]
    }
  ],
  "config_schema": [
    {
      "key": "endpoint",
      "type": "select",
      "label": {
        "en": "Endpoint",
        "fr": "Endpoint"
      },
      "description": {
        "en": "Tuya data center region of your cloud project.",
        "fr": "Région du data center Tuya de votre projet cloud."
      },
      "required": true,
      "options": [
        {
          "value": "china",
          "label": {
            "en": "China",
            "fr": "China"
          }
        },
        {
          "value": "westernAmerica",
          "label": {
            "en": "Western America",
            "fr": "Western America"
          }
        },
        {
          "value": "easternAmerica",
          "label": {
            "en": "Eastern America",
            "fr": "Eastern America"
          }
        },
        {
          "value": "centralEurope",
          "label": {
            "en": "Central Europe",
            "fr": "Central Europe"
          }
        },
        {
          "value": "westernEurope",
          "label": {
            "en": "Western Europe",
            "fr": "Western Europe"
          }
        },
        {
          "value": "india",
          "label": {
            "en": "India",
            "fr": "India"
          }
        }
      ]
    },
    {
      "key": "access_key",
      "type": "string",
      "label": {
        "en": "Client ID",
        "fr": "Client ID"
      },
      "description": {
        "en": "Access ID / Client ID of your Tuya IoT cloud project.",
        "fr": "Access ID / Client ID de votre projet cloud Tuya IoT."
      },
      "required": true
    },
    {
      "key": "secret_key",
      "type": "secret",
      "label": {
        "en": "Client Secret",
        "fr": "Client Secret"
      },
      "description": {
        "en": "Access Secret / Client Secret of your Tuya IoT cloud project.",
        "fr": "Access Secret / Client Secret de votre projet cloud Tuya IoT."
      },
      "required": true
    },
    {
      "key": "app_account_id",
      "type": "string",
      "label": {
        "en": "App account UID",
        "fr": "App account User ID"
      },
      "description": {
        "en": "UID of the Smart Life / Tuya app account linked to your cloud project.",
        "fr": "UID du compte de l'application Smart Life / Tuya lié à votre projet cloud."
      },
      "required": true
    },
    {
      "key": "app_username",
      "type": "string",
      "label": {
        "en": "Smart Life username (optional)",
        "fr": "Identifiant Smart Life (optionnel)"
      },
      "description": {
        "en": "Smart Life account email or phone.",
        "fr": "Email ou téléphone du compte Smart Life."
      },
      "required": false
    }
  ]
}
